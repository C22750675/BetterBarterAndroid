<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/auth_flow">

    <navigation android:id="@+id/auth_flow" app:startDestination="@id/welcomeFragment">
        <fragment
            android:id="@+id/welcomeFragment"
            android:name="com.hugogarry.betterbarter.ui.auth.WelcomeFragment"
            android:label="Welcome">
            <action
                android:id="@+id/action_welcomeFragment_to_loginFragment"
                app:destination="@id/loginFragment" />
            <action
                android:id="@+id/action_welcomeFragment_to_registerFragment"
                app:destination="@id/registerFragment" />
        </fragment>
        <fragment
            android:id="@+id/loginFragment"
            android:name="com.hugogarry.betterbarter.ui.auth.LoginFragment"
            android:label="Login">
            <action
                android:id="@+id/action_auth_to_main"
                app:destination="@id/main_flow"
                app:popUpTo="@id/auth_flow"
                app:popUpToInclusive="true" />
        </fragment>
        <fragment
            android:id="@+id/registerFragment"
            android:name="com.hugogarry.betterbarter.ui.auth.RegisterFragment"
            android:label="Register">
            <action
                android:id="@+id/action_auth_to_main"
                app:destination="@id/main_flow"
                app:popUpTo="@id/auth_flow"
                app:popUpToInclusive="true" />
        </fragment>
    </navigation>

    <navigation android:id="@+id/main_flow" app:startDestination="@id/mapFragment">
        <fragment
            android:id="@+id/mapFragment"
            android:name="com.hugogarry.betterbarter.ui.map.MapFragment"
            android:label="Map"
            tools:layout="@layout/fragment_map" />

        <fragment
            android:id="@+id/circlesFragment"
            android:name="com.hugogarry.betterbarter.ui.circles.CirclesFragment"
            android:label="Circles"
            tools:layout="@layout/fragment_circles">
            <action
                android:id="@+id/action_circlesFragment_to_createCircleFragment"
                app:destination="@id/createCircleFragment" />

            <action
                android:id="@+id/action_circlesFragment_to_circleDetailsFragment"
                app:destination="@id/circleDetailsFragment" />
        </fragment>

        <fragment
            android:id="@+id/createCircleFragment"
            android:name="com.hugogarry.betterbarter.ui.circles.CreateCircleFragment"
            android:label="Create Circle"
            tools:layout="@layout/fragment_create_circle" />

        <fragment
            android:id="@+id/profileFragment"
            android:name="com.hugogarry.betterbarter.ui.profile.ProfileFragment"
            android:label="Profile">
            <action
                android:id="@+id/action_profileFragment_to_addItemFragment"
                app:destination="@id/addItemFragment" />
        </fragment>

        <fragment
            android:id="@+id/addItemFragment"
            android:name="com.hugogarry.betterbarter.ui.item.AddItemFragment"
            android:label="Add Item"
            tools:layout="@layout/fragment_add_item" />

        <fragment
            android:id="@+id/tradesFragment"
            android:name="com.hugogarry.betterbarter.ui.trades.TradesFragment"
            android:label="Trades"
            tools:layout="@layout/fragment_trades">

            <action
                android:id="@+id/action_tradesFragment_to_tradeDetailsFragment"
                app:destination="@id/tradeDetailsFragment" />

            <!-- Navigation to CreateTradeFragment for editing proposals -->
            <action
                android:id="@+id/action_tradesFragment_to_createTradeFragment"
                app:destination="@id/createTradeFragment" />
        </fragment>

        <fragment
            android:id="@+id/createTradeFragment"
            android:name="com.hugogarry.betterbarter.ui.trades.CreateTradeFragment"
            android:label="Create Trade"
            tools:layout="@layout/fragment_create_trade">
            <argument
                android:name="circleId"
                app:argType="string" />
            <argument
                android:name="tradeId"
                app:argType="string"
                app:nullable="true"
                android:defaultValue="@null" />
        </fragment>

        <fragment
            android:id="@+id/circleDetailsFragment"
            android:name="com.hugogarry.betterbarter.ui.circles.CircleDetailsFragment"
            android:label="Circle Details"
            tools:layout="@layout/fragment_circle_details">

            <argument
                android:name="circleId"
                app:argType="string" />

            <action
                android:id="@+id/action_circleDetailsFragment_to_createTradeFragment"
                app:destination="@id/createTradeFragment" />

            <action
                android:id="@+id/action_circleDetailsFragment_to_tradeDetailsFragment"
                app:destination="@id/tradeDetailsFragment" />
            <action
                android:id="@+id/action_circleDetailsFragment_to_applyTradeFragment"
                app:destination="@id/applyTradeFragment" />
        </fragment>

        <fragment
            android:id="@+id/tradeDetailsFragment"
            android:name="com.hugogarry.betterbarter.ui.trades.TradeDetailsFragment"
            android:label="Trade Details"
            tools:layout="@layout/fragment_trade_details">
            <argument
                android:name="tradeId"
                app:argType="string" />
            <action
                android:id="@+id/action_tradeDetailsFragment_to_applyTradeFragment"
                app:destination="@id/applyTradeFragment" />
            <action
                android:id="@+id/action_tradeDetailsFragment_to_tradeApplicationsFragment"
                app:destination="@id/tradeApplicationsFragment" />
            <action
                android:id="@+id/action_tradeDetailsFragment_to_chatFragment"
                app:destination="@id/chatFragment" />
        </fragment>

        <fragment
            android:id="@+id/applyTradeFragment"
            android:name="com.hugogarry.betterbarter.ui.trades.ApplyTradeFragment"
            android:label="Apply for Trade"
            tools:layout="@layout/fragment_apply_trade">
            <argument
                android:name="tradeId"
                app:argType="string" />
            <argument
                android:name="existingApplication"
                app:argType="com.hugogarry.betterbarter.data.model.TradeApplication"
                app:nullable="true"
                android:defaultValue="@null" />
        </fragment>

        <fragment
            android:id="@+id/tradeApplicationsFragment"
            android:name="com.hugogarry.betterbarter.ui.trades.TradeApplicationsFragment"
            android:label="View Applications"
            tools:layout="@layout/fragment_trade_applications">
            <argument
                android:name="tradeId"
                app:argType="string" />
            <action
                android:id="@+id/action_tradeApplicationsFragment_to_chatFragment"
                app:destination="@id/chatFragment" />
        </fragment>

        <fragment
            android:id="@+id/myChatsFragment"
            android:name="com.hugogarry.betterbarter.ui.chat.MyChatsFragment"
            android:label="Chats"
            tools:layout="@layout/fragment_my_chats">
            <action
                android:id="@+id/action_myChatsFragment_to_chatFragment"
                app:destination="@id/chatFragment" />
        </fragment>

        <fragment
            android:id="@+id/chatFragment"
            android:name="com.hugogarry.betterbarter.ui.chat.ChatFragment"
            android:label="Chat"
            tools:layout="@layout/fragment_chat">
            <argument
                android:name="tradeId"
                app:argType="string" />
            <action
                android:id="@+id/action_chatFragment_to_tradeDetailsFragment"
                app:destination="@id/tradeDetailsFragment" />
        </fragment>

    </navigation>

</navigation>