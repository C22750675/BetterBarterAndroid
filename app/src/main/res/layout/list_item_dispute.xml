<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Initiator -->
        <ImageView
            android:id="@+id/imageInitiator"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ic_profile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textInitiatorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imageInitiator"
            app:layout_constraintStart_toEndOf="@id/imageInitiator"
            app:layout_constraintTop_toTopOf="@id/imageInitiator"
            tools:text="User A" />

        <!-- VS Badge -->
        <TextView
            android:id="@+id/textVs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintBottom_toBottomOf="@id/imageInitiator"
            app:layout_constraintEnd_toStartOf="@id/imageRespondent"
            app:layout_constraintStart_toEndOf="@id/textInitiatorName"
            app:layout_constraintTop_toTopOf="@id/imageInitiator" />

        <!-- Respondent -->
        <ImageView
            android:id="@+id/imageRespondent"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/ic_profile"
            app:layout_constraintEnd_toStartOf="@id/textRespondentName"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textRespondentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imageRespondent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imageRespondent"
            tools:text="User B" />

        <TextView
            android:id="@+id/textReason"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageInitiator"
            tools:text="They never showed up to the trade location." />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>