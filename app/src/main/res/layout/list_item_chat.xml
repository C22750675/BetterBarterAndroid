<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Profile Image with subtle border -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageViewChatProfile"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        tools:src="@drawable/ic_profile" />

    <!-- Name of the sender -->
    <TextView
        android:id="@+id/textViewChatName"
        style="@style/TextAppearance.Material3.TitleMedium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintEnd_toStartOf="@+id/textViewChatTime"
        app:layout_constraintStart_toEndOf="@+id/imageViewChatProfile"
        app:layout_constraintTop_toTopOf="@+id/imageViewChatProfile"
        tools:text="Alice Thompson" />

    <!-- Last message preview -->
    <TextView
        android:id="@+id/textViewLastMessage"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"
        android:alpha="0.7"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@+id/statusBadgeContainer"
        app:layout_constraintStart_toStartOf="@+id/textViewChatName"
        app:layout_constraintTop_toBottomOf="@+id/textViewChatName"
        tools:text="Sounds good, see you then at the market!" />

    <!-- Timestamp -->
    <TextView
        android:id="@+id/textViewChatTime"
        style="@style/TextAppearance.Material3.LabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.6"
        app:layout_constraintBottom_toBottomOf="@+id/textViewChatName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/textViewChatName"
        tools:text="12:30 PM" />

    <!-- Trade Status Badge (Contextual awareness) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusBadgeContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorTertiaryContainer"
        app:cardCornerRadius="6dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/imageViewChatProfile"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/textViewTradeStatus"
            style="@style/TextAppearance.Material3.LabelSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="?attr/colorOnTertiaryContainer"
            android:textStyle="bold"
            tools:text="ACCEPTED" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>